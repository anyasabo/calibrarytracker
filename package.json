{
	"name": "calibrarytracker",
	"version": "0.1.0",
	"private": true,
	"description": "Track your California public library cards, branch visits, and discover new libraries",
	"type": "module",
	"engines": {
		"node": "24.x"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:pages": "GITHUB_ACTIONS=true vite build",
		"preview": "vite preview",
		"check:data": "node scripts/check-data-coordinates.mjs",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "npm run test:smoke",
		"test:smoke": "npm run build:pages && playwright test"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^25.6.2",
		"eslint": "^10.3.0",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"svelte-eslint-parser": "^1.6.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.12"
	},
	"dependencies": {
		"dexie": "^4.4.2",
		"leaflet": "^1.9.4",
		"leaflet.markercluster": "^1.5.3"
	}
}
